{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "restore",
      "type": "process",
      "command": "dotnet",
      "args": ["restore"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": ["build", "--no-restore"],
      "dependsOn": "restore",
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "run",
      "type": "process",
      "command": "dotnet",
      "args": ["run", "--project", "src/HR23RadarRecorder.App"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test",
      "type": "process",
      "command": "dotnet",
      "args": ["run", "--project", "tests/HR23RadarRecorder.Tests"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish",
      "type": "process",
      "command": "dotnet",
      "args": [
        "publish",
        "src/HR23RadarRecorder.App",
        "-c",
        "Release",
        "-r",
        "win-x64",
        "--self-contained",
        "false"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
